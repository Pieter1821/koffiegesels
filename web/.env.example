# Copy to .env.local (gitignored). Vite exposes only VITE_* to the client.

# Browser calls this base; in dev it hits the Vite proxy (/api -> API).
VITE_API_BASE=/api

# Aspire/API URL for the Vite dev proxy (not sent to the browser).
VITE_API_PROXY_TARGET=http://localhost:5082

# Keycloak (browser talks to Keycloak directly — not proxied).
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/koffiegesels
VITE_OIDC_CLIENT_ID=koffiegesels-web
